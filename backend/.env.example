# Server
PORT=4000
NODE_ENV=development

# CORS - frontend origin
CLIENT_ORIGIN=http://localhost:5173

# Database (SQLite for dev; switch provider in schema.prisma for Postgres)
DATABASE_URL="file:./dev.db"
# Production example:
# DATABASE_URL="postgresql://user:password@localhost:5432/school_erp?schema=public"

# Auth
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="1d"

# Seed admin for the first demo school "greenwood" (used by prisma/seed.ts)
SEED_ADMIN_EMAIL="admin@school.local"
SEED_ADMIN_PASSWORD="Admin@123"
