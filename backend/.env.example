# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# CORS — must match the exact origin of your frontend
CLIENT_ORIGIN=http://localhost:5173

# ── Database ───────────────────────────────────────────────────────────────────
#
# Option 1: SQLite (default — zero-config, great for development & small deployments)
DB_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"
#
# Option 2: PostgreSQL (recommended for production)
# DB_PROVIDER="postgresql"
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/school_erp?schema=public"
#
# Popular managed PostgreSQL providers (all have free tiers):
#
#   Neon (serverless)  → https://neon.tech
#     DATABASE_URL="postgresql://username:password@ep-xxx.us-east-2.aws.neon.tech/school_erp?sslmode=require"
#
#   Supabase           → https://supabase.com
#     DATABASE_URL="postgresql://postgres:[password]@db.[ref].supabase.co:5432/postgres"
#
#   Railway            → https://railway.app
#     DATABASE_URL="postgresql://postgres:[password]@[host].railway.app:5432/railway"
#
#   Render             → https://render.com
#     DATABASE_URL="postgresql://[user]:[password]@[host]/school_erp"
#
#   Local Docker       → see docker-compose.yml
#     DATABASE_URL="postgresql://erp:erp_password@localhost:5432/school_erp"
#
# After switching to PostgreSQL for the first time, run:
#   npx prisma migrate dev --name init
#
# ──────────────────────────────────────────────────────────────────────────────

# ── Auth ──────────────────────────────────────────────────────────────────────
# MUST be at least 32 random characters in production.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
JWT_EXPIRES_IN="1d"

# ── Seed ──────────────────────────────────────────────────────────────────────
# Credentials for the first demo admin account created by prisma/seed.ts
SEED_ADMIN_EMAIL="admin@school.local"
SEED_ADMIN_PASSWORD="Admin@123"
