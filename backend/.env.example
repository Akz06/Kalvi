# ═══════════════════════════════════════════════════════════════════════════════
# School ERP — Environment Variables
# Copy this file to .env and fill in the values. Never commit .env to git.
# All Railway deployment variables are set in the Railway service dashboard.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# CORS — must exactly match your frontend origin (no trailing slash)
# Development: http://localhost:5173
# Production:  your Railway frontend URL, e.g. https://school-erp.up.railway.app
CLIENT_ORIGIN=http://localhost:5173

# ── Database (PostgreSQL — recommended for all environments) ──────────────────
#
# Railway provides a free managed PostgreSQL service.
# After creating a PostgreSQL service in Railway, copy its DATABASE_URL here.
# It will look like: postgresql://postgres:password@host.railway.internal:5432/railway
#
# The DATABASE_URL is auto-injected as an environment variable in Railway when
# you link the Postgres service to this backend service.
#
DATABASE_URL="postgresql://postgres:password@localhost:5432/school_erp"
#
# For local development you can also use Docker:
#   docker-compose up db   (starts PostgreSQL on localhost:5432)
#   DATABASE_URL="postgresql://erp:erp_password@localhost:5432/school_erp"
#
# After setting DATABASE_URL, run migrations:
#   npx prisma migrate deploy   (production / Railway)
#   npx prisma migrate dev      (local development)
#
# ─── Why PostgreSQL and not Firebase / Firestore? ─────────────────────────────
# This app has a deeply relational schema (students → enrollments → classes →
# fee records → payments). PostgreSQL provides:
#   ✓ ACID transactions (critical for financial ledger correctness)
#   ✓ Foreign-key constraints (data integrity)
#   ✓ JOINs (report cards, dashboards, fee breakdowns)
#   ✓ Native enums (Role, Gender, FeeStatus, etc.)
#   ✓ Row-level multi-tenancy via schoolId
#   ✓ Prisma ORM support (type-safe queries, migrations)
# Firebase Firestore is a document store without joins or transactions — it
# would require rewriting the entire data layer and lose financial integrity.
# ─────────────────────────────────────────────────────────────────────────────

# ── Authentication ────────────────────────────────────────────────────────────
#
# JWT_SECRET — must be a cryptographically random string, ≥ 32 characters.
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
#
# The app hard-fails at startup in production if this is weak or missing.
#
JWT_SECRET="REPLACE-WITH-A-LONG-RANDOM-SECRET-AT-LEAST-32-CHARS"

# Access token TTL. Short in production (15m) so compromised tokens expire fast.
# The refresh-token flow keeps sessions alive without re-login.
JWT_EXPIRES_IN="15m"

# Refresh token lifetime in days (default 30)
REFRESH_TOKEN_EXPIRES_DAYS=30

# ── Seed (demo data) ──────────────────────────────────────────────────────────
# Credentials for the first admin account created by `npm run db:seed`
SEED_ADMIN_EMAIL="admin@school.local"
SEED_ADMIN_PASSWORD="Admin@123"

# ── SMTP (optional — for password reset emails) ───────────────────────────────
# Each school can configure their own SMTP in Preferences → Email Settings.
# These are the global fallback values used when a school has no SMTP set.
# Leave empty to disable email features globally.
#
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT=587
# SMTP_USER="your-gmail@gmail.com"
# SMTP_PASS="your-app-password"
# SMTP_FROM="School ERP <your-gmail@gmail.com>"
