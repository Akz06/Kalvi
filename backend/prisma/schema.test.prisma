// SQLite test schema — used ONLY for local/CI unit tests.
// Mirrors schema.prisma exactly but uses sqlite provider so tests
// run without a PostgreSQL server. String fields replace native enums
// (SQLite has no native enum type).
// Generated client goes to node_modules/.prisma/test-client (separate from prod).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model School {
  id        String   @id @default(cuid())
  slug      String   @unique
  name      String
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings             SchoolSettings?
  paymentGatewayConfig PaymentGatewayConfig?
  users                User[]
  refreshTokens        RefreshToken[]
  passwordResets       PasswordResetToken[]
  classes              SchoolClass[]
  sections             Section[]
  students             Student[]
  staff                Staff[]
  attendances          Attendance[]
  fees                 FeeRecord[]
  feeHeads             FeeHead[]
  feeItems             FeeItem[]
  feePayments          FeePayment[]
  exams                Exam[]
  examResults          ExamResult[]
  academicYears        AcademicYear[]
  enrollments          Enrollment[]
  guardians            Guardian[]
}

model SchoolSettings {
  id       String @id @default(cuid())
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  city         String @default("")
  state        String @default("")
  country      String @default("India")
  addressLine  String @default("")
  phone        String @default("")
  email        String @default("")
  logoUrl      String @default("")
  tagline      String @default("")
  primaryColor String @default("")
  currency     String @default("INR")
  locale       String @default("en-IN")
  timezone     String @default("Asia/Kolkata")

  board            String @default("CBSE")
  academicYear     String @default("")
  minClassLevel    Int    @default(1)
  maxClassLevel    Int    @default(12)
  sectionsPerClass Int    @default(2)
  passPercentage   Int    @default(35)

  smtpHost   String  @default("")
  smtpPort   Int     @default(587)
  smtpUser   String  @default("")
  smtpPass   String  @default("")
  smtpFrom   String  @default("")
  smtpSecure Boolean @default(false)

  features String @default("{}")

  updatedAt DateTime @updatedAt
}

model User {
  id            String   @id @default(cuid())
  schoolId      String?
  school        School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name          String
  email         String
  password      String
  role          String   @default("ADMIN")
  active        Boolean  @default(true)
  tokenRevoked  Boolean  @default(false)
  emailVerified Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  refreshTokens  RefreshToken[]
  passwordResets PasswordResetToken[]

  @@unique([schoolId, email])
  @@index([email])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  userAgent String?
  ipAddress String?

  @@index([userId])
  @@index([schoolId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schoolId  String?
  school    School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

model SchoolClass {
  id        String    @id @default(cuid())
  schoolId  String
  school    School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  level     Int
  name      String
  createdAt DateTime  @default(now())

  sections  Section[]
  exams     Exam[]
  feeHeads  FeeHead[]

  @@unique([schoolId, level])
  @@index([schoolId])
}

model Section {
  id        String      @id @default(cuid())
  schoolId  String
  school    School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  classId   String
  class     SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  teacherId String?
  teacher   Staff?      @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  students    Student[]
  enrollments Enrollment[]
  createdAt   DateTime @default(now())

  @@unique([classId, name])
  @@index([schoolId])
}

model Student {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  admissionNo   String
  firstName     String
  lastName      String
  gender        String
  dob           DateTime
  guardianName  String
  guardianPhone String
  address       String?
  sectionId     String
  section       Section  @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  admissionDate DateTime @default(now())
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  attendances  Attendance[]
  fees         FeeRecord[]
  examResults  ExamResult[]
  enrollments  Enrollment[]
  guardians    Guardian[]

  @@unique([schoolId, admissionNo])
  @@index([schoolId])
  @@index([sectionId])
}

model Staff {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  employeeNo   String
  firstName    String
  lastName     String
  gender       String
  email        String
  phone        String
  designation  String
  subject      String?
  joiningDate  DateTime @default(now())
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sectionsMentor Section[]

  @@unique([schoolId, employeeNo])
  @@unique([schoolId, email])
  @@index([schoolId])
}

model Attendance {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String   @default("PRESENT")
  remark    String?
  createdAt DateTime @default(now())

  @@unique([studentId, date])
  @@index([schoolId])
  @@index([date])
}

model FeeHead {
  id            String      @id @default(cuid())
  schoolId      String
  school        School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  classId       String
  class         SchoolClass @relation(fields: [classId], references: [id], onDelete: Cascade)
  name          String
  defaultAmount Int         @default(0)
  active        Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  items FeeItem[]

  @@unique([classId, name])
  @@index([schoolId])
  @@index([classId])
}

model FeeRecord {
  id             String        @id @default(cuid())
  schoolId       String
  school         School        @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  title          String
  amount         Int
  amountPaid     Int           @default(0)
  status         String        @default("PENDING")
  dueDate        DateTime
  paidDate       DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  items    FeeItem[]
  payments FeePayment[]

  @@index([schoolId])
  @@index([studentId])
  @@index([academicYearId])
  @@index([status])
}

model FeeItem {
  id          String    @id @default(cuid())
  schoolId    String
  school      School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeRecordId String
  feeRecord   FeeRecord @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)
  feeHeadId   String
  feeHead     FeeHead   @relation(fields: [feeHeadId], references: [id], onDelete: Restrict)
  amount      Int
  createdAt   DateTime  @default(now())

  @@index([schoolId])
  @@index([feeRecordId])
}

model FeePayment {
  id          String   @id @default(cuid())
  schoolId    String
  school      School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeRecordId String
  feeRecord   FeeRecord @relation(fields: [feeRecordId], references: [id], onDelete: Cascade)
  amount      Int
  mode        String   @default("CASH")
  reference   String?
  receiptNo   String   @unique
  paidAt      DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([schoolId])
  @@index([feeRecordId])
}

model PaymentGatewayConfig {
  id       String @id @default(cuid())
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  provider      String  @default("MANUAL")
  mode          String  @default("TEST")
  keyId         String  @default("")
  keySecret     String  @default("")
  webhookSecret String  @default("")
  enabledModes  String  @default("[\"CASH\",\"CARD\",\"UPI\",\"BANK\",\"CHEQUE\",\"ONLINE\"]")
  active        Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Guardian {
  id           String   @id @default(cuid())
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  name         String
  relationship String   @default("Parent")
  phone        String
  email        String
  password     String
  isPrimary    Boolean  @default(true)
  active       Boolean  @default(true)
  tokenRevoked Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  refreshTokens  GuardianRefreshToken[]
  passwordResets GuardianPasswordReset[]

  @@unique([schoolId, email])
  @@index([schoolId])
  @@index([studentId])
}

model GuardianRefreshToken {
  id         String   @id @default(cuid())
  guardianId String
  guardian   Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  userAgent  String?
  ipAddress  String?

  @@index([guardianId])
}

model GuardianPasswordReset {
  id         String   @id @default(cuid())
  guardianId String
  guardian   Guardian @relation(fields: [guardianId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([guardianId])
}

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String
  school    School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name      String
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enrollments Enrollment[]
  exams       Exam[]
  fees        FeeRecord[]

  @@unique([schoolId, name])
  @@index([schoolId])
}

model Enrollment {
  id             String      @id @default(cuid())
  schoolId       String
  school         School      @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  studentId      String
  student        Student     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  sectionId      String
  section        Section     @relation(fields: [sectionId], references: [id], onDelete: Restrict)
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  status         String      @default("ACTIVE")
  promotedAt     DateTime?
  createdAt      DateTime    @default(now())

  @@unique([studentId, academicYearId])
  @@index([schoolId])
  @@index([academicYearId])
  @@index([sectionId])
}

model Exam {
  id             String       @id @default(cuid())
  schoolId       String
  school         School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  name           String
  classId        String
  class          SchoolClass  @relation(fields: [classId], references: [id], onDelete: Cascade)
  academicYearId String?
  academicYear   AcademicYear? @relation(fields: [academicYearId], references: [id], onDelete: SetNull)
  subject        String
  maxMarks       Float        @default(100)
  examDate       DateTime
  createdAt      DateTime     @default(now())

  results ExamResult[]

  @@index([schoolId])
  @@index([classId])
  @@index([academicYearId])
}

model ExamResult {
  id            String   @id @default(cuid())
  schoolId      String
  school        School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  examId        String
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marksObtained Float
  grade         String?
  remark        String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([examId, studentId])
  @@index([schoolId])
  @@index([studentId])
}
