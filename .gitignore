# ── Dependencies ──────────────────────────────────────────────
node_modules/

# ── Build outputs ─────────────────────────────────────────────
dist/
build/
backend/dist/
frontend/dist/
*.tsbuildinfo

# ── Environment / Secrets (NEVER commit) ──────────────────────
.env
.env.local
.env.*.local
backend/.env
frontend/.env

# ── Database files (SQLite dev DB) ────────────────────────────
backend/prisma/*.db
backend/prisma/*.db-journal
backend/prisma/*.db-shm
backend/prisma/*.db-wal
*.sqlite
*.sqlite3

# ── Logs ──────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Test / Coverage ───────────────────────────────────────────
coverage/
.nyc_output/

# ── OS artefacts ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# ── Zoho Code IDE ─────────────────────────────────────────────
.zcode/

# ── Prisma generated client (regenerated from schema) ─────────
backend/node_modules/.prisma/

# ── React-PDF / PDF build artefacts ───────────────────────────
frontend/src/**/*.pdf
