# ═══════════════════════════════════════════════════════════════════════════════
# Kalvi School ERP — Frontend Environment Variables
# Copy to .env and fill in the values. Never commit .env to git.
# ═══════════════════════════════════════════════════════════════════════════════

# Backend API base URL
# Development : http://localhost:4000
# Production  : your Railway backend service URL
VITE_API_URL=http://localhost:4000

# Google OAuth Client ID (public — safe to expose in frontend)
# Get from: console.cloud.google.com → APIs & Services → Credentials
VITE_GOOGLE_CLIENT_ID=
